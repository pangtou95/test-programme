    "e2e",
    "quality-gate",
    "load-test",
    "concurrency",
    "mobile-app",
    "desktop-app",
    "testing"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "playwright": "^1.59.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
