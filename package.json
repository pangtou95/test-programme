{
  "name": "universal-quality-gate",
  "version": "0.1.0",
  "description": "Product-grade quality test system for Web, browser, desktop app, mobile app, E2E, concurrency, load, CI gates, and agent-friendly workflows.",
  "type": "module",
  "bin": {
    "quality-test": "./bin/quality-test.mjs"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
